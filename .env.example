# Docker / host
# Allinea UID/GID all'utente host (`id -u` / `id -g`) per evitare problemi di
# permessi sui volumi bind. Su macOS tipicamente UID=501 GID=20, su Linux 1000/1000.
UID=1000
GID=1000
APP_PORT=8080

# MySQL
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=finance
DB_USERNAME=finance
DB_PASSWORD=finance
DB_ROOT_PASSWORD=rootsecret
