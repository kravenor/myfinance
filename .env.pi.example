# .env.pi.example — Configurazione Raspberry Pi (copia in .env.pi)
# Descrizione: questo file configura il deploy del progetto finance su Raspberry Pi 4

# === NETWORKING (rete locale) ===
# IP locale della Pi sulla rete (es. 192.168.1.100)
# Per trovarlo: hostname -I
PI_LOCAL_IP=192.168.1.100

# Porta di accesso (default 8080)
APP_PORT=8080

# === STORAGE (SSD esterno USB3) ===
# Path alla cartella dati su SSD esterno
# Esempio con SSD esterno montato su /mnt/ssd:
MYSQL_DATA_PATH=/mnt/ssd/mysql_data
REDIS_DATA_PATH=/mnt/ssd/redis_data

# === DATABASE ===
DB_PORT=3306
DB_DATABASE=finance
DB_USERNAME=finance
DB_PASSWORD=finance123
DB_ROOT_PASSWORD=rootsecret123

# === UID/GID (per permessi file) ===
# Tipicamente 1000 su Linux, 501 su macOS
# Esegui: id -u; id -g
UID=1000
GID=1000

# === LARAVEL (.env backend, copiato da backend/.env.example) ===
# Popolare dal template backend/.env.example:
APP_NAME=Finance
APP_ENV=production
APP_DEBUG=false
APP_KEY=  # Generato da: docker compose -f docker-compose.pi.yml exec php php artisan key:generate
APP_URL=http://192.168.1.100:8080

DB_HOST=mysql
DB_CONNECTION=mysql

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

MAIL_MAILER=log

SANCTUM_STATEFUL_DOMAINS=192.168.1.100:8080
SESSION_DOMAIN=.192.168.1.100

# Se hai un dominio locale (es. finance.local):
# SESSION_DOMAIN=.finance.local
# SANCTUM_STATEFUL_DOMAINS=finance.local:8080
# APP_URL=http://finance.local:8080
