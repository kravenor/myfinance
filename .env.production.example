# Stack produzione - rinominare in .env.production e completare i valori
# Su VPS con Apache/nginx host davanti (docker-compose.vps.yml): APP_PORT deve essere
# una porta libera diversa da 80/443, che restano al webserver host. Il vhost host
# fa da reverse proxy verso 127.0.0.1:APP_PORT.
APP_PORT=8080

# Laravel
APP_NAME=Finance
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://finance.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=finance
DB_USERNAME=finance
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME

# Cache / sessione / queue
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=finance.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum
SANCTUM_STATEFUL_DOMAINS=finance.example.com
FRONTEND_URL=https://finance.example.com

# Mail (opzionale)
MAIL_MAILER=log
